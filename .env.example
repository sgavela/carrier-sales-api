# API authentication
API_KEY=change-me-to-a-strong-random-secret

# FMCSA integration
FMCSA_WEBKEY=your-fmcsa-webkey-here
FMCSA_MOCK=false

# Database
DATABASE_URL=sqlite:///./data/carrier_sales.db

# Server
PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://app.happyrobot.ai

# Negotiation parameters (percentages as decimals)
MAX_MARGIN_PCT=0.12
ROUND1_CEILING_PCT=0.12
ROUND1_COUNTER_PCT=0.05
ROUND2_CEILING_PCT=0.10
ROUND2_BLEND_RATIO=0.75
ROUND3_ACCEPT_PCT=0.08
MAX_ROUNDS=3
